{
  "snp5.3:0.1": "Lehrreden-Sammelband 5.3 ",
  "snp5.3:0.2": "Die Fragen des Vedenstudenten Tissametteyya ",
  "snp5.3:1.1": "„Wer hier in der Welt ist zufrieden?“, ",
  "snp5.3:1.2": "sagte der Ehrwürdige Tissametteyya. ",
  "snp5.3:1.3": "„Wer hat keine Bewegungen? ",
  "snp5.3:1.4": "Welcher Bedachte hat beide Enden verstanden ",
  "snp5.3:1.5": "und steckt nicht in der Mitte fest? ",
  "snp5.3:1.6": "Von wem sagen sie, er sei ein großer Mann? ",
  "snp5.3:1.7": "Wer hier ist der Näherin entronnen?“ ",
  "snp5.3:2.1": "„Er führt das geistliche Leben inmitten von Sinnenfreuden“, ",
  "snp5.3:2.2": "sagte der Buddha zu Metteya, ",
  "snp5.3:2.3": "„ohne Verlangen, stets achtsam; ",
  "snp5.3:2.4": "ein Mönch, der nach Abschätzung verloschen ist: ",
  "snp5.3:2.5": "Er ist es, der keine Bewegungen hat. ",
  "snp5.3:3.1": "Dieser Bedachte hat beide Enden verstanden ",
  "snp5.3:3.2": "und steckt nicht in der Mitte fest. ",
  "snp5.3:3.3": "Ein großer Mann ist er, erkläre ich; ",
  "snp5.3:3.4": "der Näherin ist er hier entronnen.“ "
}