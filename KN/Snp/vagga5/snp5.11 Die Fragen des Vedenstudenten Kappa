{
  "snp5.11:0.1": "Lehrreden-Sammelband 5.11 ",
  "snp5.11:0.2": "Die Fragen des Vedenstudenten Kappa ",
  "snp5.11:1.1": "„Für die, die von Alter und Tod überwältigt sind“, ",
  "snp5.11:1.2": "sagte der Ehrwürdige Kappa, ",
  "snp5.11:1.3": "„die mitten im Strom festhängen, ",
  "snp5.11:1.4": "da die schreckliche Flut herankommt, ",
  "snp5.11:1.5": "nenne mir eine Insel, Kamerad. ",
  "snp5.11:1.6": "Erkläre mir eine Insel, ",
  "snp5.11:1.7": "sodass dies nicht weiter geschehen kann.“ ",
  "snp5.11:2.1": "„Für die, die von Alter und Tod überwältigt sind“, ",
  "snp5.11:2.2": "sagte der Buddha zu Kappa, ",
  "snp5.11:2.3": "„die mitten im Strom festhängen, ",
  "snp5.11:2.4": "da die schreckliche Flut herankommt, ",
  "snp5.11:2.5": "werde ich dir eine Insel nennen, Kappa. ",
  "snp5.11:3.1": "Nichts haben und nichts nehmen: ",
  "snp5.11:3.2": "Das ist die Insel ohne ein Weiteres. ",
  "snp5.11:3.3": "Ich nenne sie Erlöschen, ",
  "snp5.11:3.4": "die Auflösung von Alter und Tod. ",
  "snp5.11:4.1": "Die, die das vollständig verstanden haben, achtsam, ",
  "snp5.11:4.2": "sind in diesem Leben verloschen. ",
  "snp5.11:4.3": "Sie geraten weder in Māras Bann, ",
  "snp5.11:4.4": "noch sind sie seine Bediensteten.“ "
}